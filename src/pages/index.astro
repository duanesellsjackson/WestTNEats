---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="WestTNEats | Food Trucks in West Tennessee"
  description="Find food trucks in Jackson, Milan, Dyersburg, Paris, and all over West Tennessee. A free community map built by the community, for the community."
>
  <section class="hero">
    <div class="container">
      <h1>Find Your Next<br />Favorite Truck.</h1>
      <p class="subhead">Every food truck in West Tennessee, on one free map.</p>
      <div class="hero-actions">
        <a href="/map/" class="btn btn-primary">Explore the Map</a>
        <a href="/map/#register" class="btn btn-secondary">Add Your Truck</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 3.5rem;
    text-align: center;
  }

  .hero h1 {
    font-weight: 900;
    font-size: 2.5rem;
    color: var(--color-night-market);
    margin: 0 0 1rem;
  }

  .subhead {
    font-size: 15px;
    color: var(--color-muted);
    margin: 0 auto;
    max-width: 36rem;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2rem;
    align-items: center;
  }

  .btn {
    display: inline-block;
    width: 100%;
    max-width: 20rem;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .btn:hover {
    opacity: 0.9;
    transform: scale(1.02);
  }

  .btn-primary {
    background: var(--color-tailgate-red);
    color: #fff;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-night-market);
    border: 1.5px solid var(--color-night-market);
  }

  @media (min-width: 48rem) {
    .hero h1 {
      font-size: 3.5rem;
    }

    .hero-actions {
      flex-direction: row;
      justify-content: center;
    }

    .btn {
      width: auto;
    }
  }
</style>
