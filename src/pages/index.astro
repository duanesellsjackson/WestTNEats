---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="WestTNEats | Food Trucks in West Tennessee"
  description="Find food trucks in Jackson, Milan, Dyersburg, Paris, and all over West Tennessee. A free community map built by the community, for the community."
>
  <section class="hero">
    <div class="container">
      <h1>Find food trucks in West Tennessee</h1>
      <p>
        A free community map for Jackson, Milan, Dyersburg, Paris, and beyond.
        No fees. No gatekeeping. Just good local food.
      </p>
      <a href="/map/" class="cta">Open the map</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 3rem;
    text-align: center;
  }

  .hero h1 {
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .hero p {
    max-width: 36rem;
    margin-inline: auto;
    color: var(--color-muted);
  }

  .cta {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
  }

  .cta:hover {
    background: var(--color-accent-dark);
    color: #fff;
  }

  @media (min-width: 48rem) {
    .hero h1 {
      font-size: 2.75rem;
    }
  }
</style>
