---
// Layer 1: interactive Leaflet.js map with Turso self-registration.
import BaseLayout from '../layouts/BaseLayout.astro';
import TruckMap from '../components/map/TruckMap.astro';
import RegisterForm from '../components/map/RegisterForm.astro';
---

<BaseLayout
  title="Food Truck Map | WestTNEats"
  description="Interactive map of food trucks across West Tennessee. Truck owners can add themselves for free."
>
  <section class="container">
    <h1>The Map</h1>
    <p>Every food truck in West Tennessee, in one place. Tap a pin to see hours and contact info.</p>
    <TruckMap />
    <RegisterForm />
  </section>
</BaseLayout>
