---
// Self-registration for truck owners. Free, simple, no account needed.
// New trucks go in as pending and show on the map once approved.
import { CITY_NAMES } from '../../lib/cities';
---

<section class="register" id="register">
  <div class="register-card">
    <h2>Put Your Truck on the Map.</h2>
    <p class="subline">Free. No catch. Takes 2 minutes.</p>

    <form id="register-form">
      <label>
        Truck name *
        <input type="text" name="name" required maxlength="100" autocomplete="organization" />
      </label>

      <label>
        Owner name *
        <input type="text" name="owner" required maxlength="100" autocomplete="name" />
      </label>

      <label>
        City *
        <select name="city" required>
          <option value="" disabled selected>Pick your city</option>
          {CITY_NAMES.map((city) => <option value={city}>{city}</option>)}
        </select>
      </label>

      <label>
        Cuisine type *
        <input type="text" name="cuisine" required maxlength="50" placeholder="BBQ, tacos, Filipino, burgers…" />
      </label>

      <label>
        Hours *
        <input type="text" name="hours" required maxlength="200" placeholder="Tue-Sat 11am-7pm" />
      </label>

      <label>
        Phone
        <input type="tel" name="phone" maxlength="30" autocomplete="tel" />
      </label>

      <label>
        Instagram
        <input type="text" name="instagram" maxlength="60" placeholder="@yourtruck" />
      </label>

      <button type="submit">Add Me to the Map</button>
      <p id="form-status" role="status"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const button = form.querySelector('button')!;

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    button.disabled = true;
    status.textContent = 'Sending…';

    try {
      const res = await fetch('/api/trucks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const result = await res.json();

      if (!res.ok) throw new Error(result.error || 'Something went wrong');

      form.reset();
      status.textContent = "Got it! We'll review your truck and add it to the map soon.";
    } catch (err) {
      status.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      button.disabled = false;
      return;
    }
    button.disabled = false;
  });
</script>

<style>
  .register {
    padding-block: 2rem;
  }

  .register-card {
    max-width: 480px;
    margin-inline: auto;
    background: #fff;
    border: 0.5px solid #ddd;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .register-card h2 {
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0 0 0.25rem;
  }

  .subline {
    color: var(--color-muted);
    margin: 0 0 1.25rem;
  }

  form {
    display: grid;
    gap: 1rem;
  }

  label {
    display: grid;
    gap: 0.3rem;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-night-market);
  }

  input,
  select {
    font: inherit;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    min-height: 44px;
    padding: 0.6rem;
    border: 1.5px solid #ddd;
    border-radius: var(--radius-md);
    background: #fafafa;
    width: 100%;
  }

  input:focus,
  select:focus {
    outline: 2px solid var(--color-tailgate-red);
    outline-offset: 1px;
  }

  button {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    width: 100%;
    min-height: 44px;
    padding: 0.75rem;
    border: none;
    border-radius: var(--radius-md);
    background: var(--color-tailgate-red);
    color: #fff;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  button:hover {
    opacity: 0.9;
    transform: scale(1.01);
  }

  button:disabled {
    opacity: 0.6;
    cursor: wait;
    transform: none;
  }

  #form-status {
    min-height: 1.5em;
    margin: 0;
    font-size: 0.9rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    color: var(--color-muted);
  }
</style>
