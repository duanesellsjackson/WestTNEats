---
// Self-registration for truck owners. Free, simple, no account needed.
// New trucks go in as pending and show on the map once approved.
import { CITY_NAMES } from '../../lib/cities';
---

<section class="register">
  <h2>Own a food truck? Get on the map. It's free.</h2>
  <p>Fill this out and we'll add your truck once we review it. No fees, ever.</p>

  <form id="register-form">
    <label>
      Truck name *
      <input type="text" name="name" required maxlength="100" autocomplete="organization" />
    </label>

    <label>
      Owner name *
      <input type="text" name="owner" required maxlength="100" autocomplete="name" />
    </label>

    <label>
      City *
      <select name="city" required>
        <option value="" disabled selected>Pick your city</option>
        {CITY_NAMES.map((city) => <option value={city}>{city}</option>)}
      </select>
    </label>

    <label>
      Cuisine type *
      <input type="text" name="cuisine" required maxlength="50" placeholder="BBQ, tacos, Filipino, burgers…" />
    </label>

    <label>
      Hours *
      <input type="text" name="hours" required maxlength="200" placeholder="Tue-Sat 11am-7pm" />
    </label>

    <label>
      Phone
      <input type="tel" name="phone" maxlength="30" autocomplete="tel" />
    </label>

    <label>
      Instagram
      <input type="text" name="instagram" maxlength="60" placeholder="@yourtruck" />
    </label>

    <button type="submit">Add my truck</button>
    <p id="form-status" role="status"></p>
  </form>
</section>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const button = form.querySelector('button')!;

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    button.disabled = true;
    status.textContent = 'Sending…';

    try {
      const res = await fetch('/api/trucks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const result = await res.json();

      if (!res.ok) throw new Error(result.error || 'Something went wrong');

      form.reset();
      status.textContent = "Got it! We'll review your truck and add it to the map soon.";
    } catch (err) {
      status.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      button.disabled = false;
      return;
    }
    button.disabled = false;
  });
</script>

<style>
  .register {
    max-width: 28rem;
    margin-inline: auto;
    padding-block: 1.5rem;
  }

  .register h2 {
    font-size: 1.4rem;
    line-height: 1.3;
  }

  form {
    display: grid;
    gap: 1rem;
  }

  label {
    display: grid;
    gap: 0.25rem;
    font-weight: 600;
    font-size: 0.95rem;
  }

  input,
  select {
    font: inherit;
    font-weight: 400;
    padding: 0.65rem;
    border: 1px solid #cfc7ba;
    border-radius: 0.375rem;
    background: #fff;
    width: 100%;
  }

  input:focus,
  select:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  button {
    font: inherit;
    font-weight: 600;
    padding: 0.75rem;
    border: none;
    border-radius: 0.5rem;
    background: var(--color-accent);
    color: #fff;
    cursor: pointer;
  }

  button:hover {
    background: var(--color-accent-dark);
  }

  button:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  #form-status {
    min-height: 1.5em;
    margin: 0;
    color: var(--color-muted);
  }
</style>
