---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="container">
        <a href="/" class="brand">WestTNEats</a>
        <div class="nav-links">
          <a href="/map/">Map</a>
          <a href="/blog/">Blog</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>WestTNEats. Built by the community, for the community.</p>
        <p>Jeepney Ventures, LLC. Built for the people. Powered by purpose.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--color-accent);
  }

  .site-header nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.75rem;
  }

  .brand {
    color: #fff;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1rem;
  }

  .nav-links a {
    color: #fff;
    text-decoration: none;
  }

  .nav-links a:hover {
    text-decoration: underline;
  }

  .site-footer {
    margin-top: 3rem;
    padding-block: 1.5rem;
    background: #f4efe7;
    color: var(--color-muted);
    font-size: 0.875rem;
    text-align: center;
  }

  .site-footer p {
    margin: 0.25rem 0;
  }
</style>
